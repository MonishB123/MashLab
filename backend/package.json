{
  "name": "mashlab-backend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "python -m uvicorn api:app --host 0.0.0.0 --port 8787 --app-dir ./mashup_backend",
    "dev:reload": "python -m uvicorn api:app --reload --host 0.0.0.0 --port 8787 --app-dir ./mashup_backend",
    "start": "python -m uvicorn api:app --host 0.0.0.0 --port 8787 --app-dir ./mashup_backend",
    "install:deps": "python -m pip install -r mashup_backend/requirements.txt"
  }
}
